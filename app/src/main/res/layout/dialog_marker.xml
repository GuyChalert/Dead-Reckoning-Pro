<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/select_emoji"
        android:textColor="@color/textPrimary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/emojiContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/emoji_pin"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="📍"
                android:textSize="28sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/emoji_pushpin"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="📌"
                android:textSize="28sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/emoji_home"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="🏠"
                android:textSize="28sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/emoji_building"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="🏢"
                android:textSize="28sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/emoji_restaurant"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="🍔"
                android:textSize="28sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/emoji_pizza"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="🍕"
                android:textSize="28sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/emoji_coffee"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="☕"
                android:textSize="28sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/emoji_shopping"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="🛒"
                android:textSize="28sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/emoji_hospital"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="🏥"
                android:textSize="28sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/emoji_fuel"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="⛽"
                android:textSize="28sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/emoji_hotel"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="🏨"
                android:textSize="28sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/emoji_park"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="🏞"
                android:textSize="28sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/emoji_car"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="🚗"
                android:textSize="28sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/emoji_plane"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="✈️"
                android:textSize="28sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/emoji_star"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="⭐"
                android:textSize="28sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/emoji_heart"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="❤️"
                android:textSize="28sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/emoji_red_dot"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="🔴"
                android:textSize="28sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/emoji_green_dot"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="🟢"
                android:textSize="28sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>

    </HorizontalScrollView>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="@string/marker_label_hint"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editMarkerLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLines="1" />

    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonCancelMarker"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cancel" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonConfirmMarker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/confirm"
            app:backgroundTint="@color/colorAccent" />

    </LinearLayout>

</LinearLayout>
